# SEND Assistant — Environment Variables
# Copy this to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (relative to project root)
DB_PATH=./data/send-assistant.db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave blank in development — emails will be logged to console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=SEND Assistant <noreply@yourdomain.com>

# ── Google OAuth (optional — for Google Sign-In) ──────────────────────────────
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Frontend API base URL ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
